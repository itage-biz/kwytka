@page "/admin"
@rendermode InteractiveServer
@using AnyAscii
@using Slugify
@inject Configuration.IConfigurationService ConfigurationService
@inject Microsoft.Extensions.Options.IOptions<Configuration.TableFormattingOptions> TableOptions
<PageTitle>Адміністрування - Квітка</PageTitle>
<QuillAssets/>

<section class="admin-page" aria-labelledby="admin-title">
    <header class="admin-header">
        <div>
            <h1 id="admin-title">Адміністрування</h1>
        </div>
        <div class="admin-actions">
            <form method="get" action="/admin/settings.json" target="settings-export">
                <button class="download-button" type="submit">Експорт</button>
            </form>
            <iframe name="settings-export" hidden></iframe>
            <form class="upload-settings-form" method="post" action="/admin/settings.json" enctype="multipart/form-data">
                <AntiforgeryToken/>
                <label class="upload-button">
                    Імпорт
                    <input type="file" name="settingsFile" accept="application/json" required
                           onchange="this.form.submit()"/>
                </label>
            </form>
            <button class="save-button" type="button" disabled="@_isSaving" @onclick="SaveAsync">
                @(_isSaving ? "Збереження..." : "Зберегти зміни")
            </button>
        </div>
    </header>

    @if (_saveMessage is not null)
    {
        <p class="save-message" role="status">@_saveMessage</p>
    }

    <section class="settings-section" aria-labelledby="price-list-prefix-title">
        <div class="section-heading">
            <p class="section-number">01</p>
            <h2 id="price-list-prefix-title">Текст на сторінках прайсів</h2>
        </div>
        <div class="price-list-prefix-editor">
            <QuillEditor @bind-Value="_data.PriceListPrefix" MinHeight="8rem"/>
        </div>
    </section>

    <section class="settings-section" aria-labelledby="sale-title">
        <div class="section-heading">
            <p class="section-number">02</p>
            <h2 id="sale-title">Розпродаж</h2>
        </div>

        <label class="sale-toggle">
            <input type="checkbox" @bind="_data.IsSaleEnabled"/>
            <span class="toggle-track" aria-hidden="true"></span>
            <span>Розпродаж увімкнуто</span>
        </label>

        <div class="price-list-content-field">
            <div class="price-list-content-heading">
                <label for="sale-page-content">Таблиця розпродажу</label>
                <div class="price-list-content-actions">
                    <button type="button" class="price-list-clear-button" title="Очистити вміст"
                            aria-label="Очистити таблицю розпродажу" @onclick="ClearSalePageContent">×</button>
                    <button type="button" class="price-list-preview-button"
                            disabled="@string.IsNullOrWhiteSpace(_data.SalePageHtml)"
                            @onclick="OpenSalePreview">
                        Попередній перегляд
                    </button>
                </div>
            </div>
            <PasteableTableInput id="sale-page-content" class="price-list-content-input"
                                 @bind-Value="_data.SalePageHtml"></PasteableTableInput>
        </div>
    </section>

    <section class="settings-section" aria-labelledby="price-lists-title">
        <div class="price-lists-header">
            <div class="section-heading">
                <p class="section-number">03</p>
                <h2 id="price-lists-title">Прайс-листи</h2>
            </div>
            <button class="add-button" type="button" @onclick="AddPriceList">+ Додати прайс-лист</button>
        </div>

        @if (_data.PriceLists.Count == 0)
        {
            <p class="price-list-empty">Прайс-листів ще немає.</p>
        }
        else
        {
            <div class="price-list-cards">
                @for (var index = 0; index < _data.PriceLists.Count; index++)
                {
                    var priceListIndex = index;
                    var priceList = _data.PriceLists[priceListIndex];

                    <article class="price-list-card" @key="priceList">
                        <div class="price-list-card-content">
                            <p class="card-index">Прайс-лист @(priceListIndex + 1)</p>
                            <div class="price-list-fields">
                                <label>
                                    <span>Назва</span>
                                    <input @bind="priceList.Title"/>
                                </label>
                            </div>
                            <div class="price-list-content-field">
                                <div class="price-list-content-heading">
                                    <label for="@($"price-list-content-{priceListIndex}")">HTML-вміст</label>
                                    <div class="price-list-content-actions">
                                        <button type="button" class="price-list-clear-button" title="Очистити вміст"
                                                aria-label="Очистити HTML-вміст"
                                                @onclick="() => ClearPriceListContent(priceListIndex)">×</button>
                                        <button type="button" class="price-list-preview-button"
                                                disabled="@string.IsNullOrWhiteSpace(priceList.HtmlContent)"
                                                @onclick="() => OpenPreview(priceList.Title, priceList.HtmlContent)">
                                            Попередній перегляд
                                        </button>
                                    </div>
                                </div>
                                <PasteableTableInput id="@($"price-list-content-{priceListIndex}")"
                                                     class="price-list-content-input"
                                                     @bind-Value="priceList.HtmlContent"></PasteableTableInput>
                            </div>
                        </div>
                        <div class="price-list-actions" aria-label="Дії з прайс-листом">
                            <button type="button" title="Перемістити вище" aria-label="Перемістити вище"
                                    disabled="@(priceListIndex == 0)"
                                    @onclick="() => MovePriceList(priceListIndex, -1)">↑
                            </button>
                            <button type="button" title="Перемістити нижче" aria-label="Перемістити нижче"
                                    disabled="@(priceListIndex == _data.PriceLists.Count - 1)"
                                    @onclick="() => MovePriceList(priceListIndex, 1)">↓
                            </button>
                            <button class="delete-button" type="button" title="Видалити прайс-лист"
                                    aria-label="Видалити прайс-лист" @onclick="() => DeletePriceList(priceListIndex)">×
                            </button>
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</section>

@if (_previewHtml is not null)
{
    <div class="price-list-preview-backdrop" @onclick="ClosePreview">
        <section class="price-list-preview-modal" role="dialog" aria-modal="true"
                 aria-labelledby="price-list-preview-title" @onclick:stopPropagation="true"
                 @onkeydown="HandlePreviewKeyDown">
            <header class="price-list-preview-header">
                <h2 id="price-list-preview-title">@_previewTitle</h2>
                <button type="button" class="price-list-preview-close" aria-label="Закрити попередній перегляд"
                        @ref="_previewCloseButton" @onclick="ClosePreview">×</button>
            </header>
            <div class="price-list-preview-content" data-count-columns="@TableOptions.Value.CountColumns">
                @((MarkupString)_previewHtml)
            </div>
        </section>
    </div>
}

<script type="module" src="@Assets["table-column-formatting.js"]"></script>

@code {
    private static readonly SlugHelper SSlugHelper = new();

    private bool _isSaving;
    private bool _focusPreviewCloseButton;
    private string? _saveMessage;
    private string? _previewHtml;
    private string _previewTitle = string.Empty;
    private Configuration.ConfigurationData _data = new();
    private ElementReference _previewCloseButton;

    protected override void OnInitialized()
    {
        _data = ConfigurationService.Data;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_focusPreviewCloseButton)
        {
            return;
        }

        _focusPreviewCloseButton = false;
        await _previewCloseButton.FocusAsync();
    }

    private void AddPriceList()
    {
        _data.PriceLists.Add(new Kwytka.Configuration.PriceList());
        _saveMessage = null;
    }

    private void DeletePriceList(int index)
    {
        _data.PriceLists.RemoveAt(index);
        _saveMessage = null;
    }

    private void MovePriceList(int index, int direction)
    {
        var targetIndex = index + direction;
        if (targetIndex < 0 || targetIndex >= _data.PriceLists.Count)
        {
            return;
        }

        var priceList = _data.PriceLists[index];
        _data.PriceLists.RemoveAt(index);
        _data.PriceLists.Insert(targetIndex, priceList);
        _saveMessage = null;
    }

    private async Task SaveAsync()
    {
        _isSaving = true;
        _saveMessage = null;

        try
        {
            foreach (var priceList in _data.PriceLists)
            {
                priceList.Slug = SSlugHelper.GenerateSlug(priceList.Title.Transliterate());
            }

            await ConfigurationService.SaveAsync(_data);
            _saveMessage = "Зміни збережено.";
        }
        catch (InvalidDataException exception)
        {
            _saveMessage = exception.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void ClearPriceListContent(int index)
    {
        _data.PriceLists[index].HtmlContent = string.Empty;
    }

    private void ClearSalePageContent()
    {
        _data.SalePageHtml = string.Empty;
    }

    private void OpenSalePreview()
    {
        OpenPreview("Розпродаж", _data.SalePageHtml);
    }

    private void OpenPreview(string title, string html)
    {
        if (string.IsNullOrWhiteSpace(html))
        {
            return;
        }

        _previewTitle = string.IsNullOrWhiteSpace(title) ? "Попередній перегляд" : title;
        _previewHtml = html;
        _focusPreviewCloseButton = true;
    }

    private void ClosePreview()
    {
        _previewHtml = null;
        _previewTitle = string.Empty;
    }

    private void HandlePreviewKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Escape")
        {
            ClosePreview();
        }
    }

}
