@page "/sale"
@inject Configuration.IConfigurationService ConfigurationService
@inject Microsoft.Extensions.Options.IOptions<Configuration.TableFormattingOptions> TableOptions

<PageTitle>Розпродаж - Квітка</PageTitle>

<section class="sale-page" aria-labelledby="sale-title">
    <h1 id="sale-title">Розпродаж</h1>
    <div class="table-scroll-container" data-count-columns="@TableOptions.Value.CountColumns">
        @((MarkupString)ConfigurationService.Data.SalePageHtml)
    </div>
</section>

<script type="module" src="@Assets["table-column-formatting.js"]"></script>
