@inject IJSRuntime JsRuntime

@implements IAsyncDisposable

<textarea @ref="_textareaElement" @bind="Value" @bind:event="oninput" onpaste="window.alert" readonly @attributes="AdditionalAttributes"></textarea>

@code {
    [Parameter] public string Value { get; set; } = string.Empty;

    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    [Parameter] public EventCallback TableUpdated { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? AdditionalAttributes { get; set; }

    private const string ModuleFileName = "/pasteable-table-input.js";

    private IJSObjectReference? _module;
    private DotNetObjectReference<PasteableTableInput>? _dotNetReference;
    private ElementReference _textareaElement;
    private bool _isDisposed;

    private string ModulePath => ModuleFileName;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _isDisposed)
        {
            return;
        }

        _module = await JsRuntime.InvokeAsync<IJSObjectReference>("import", ModulePath);
        _dotNetReference = DotNetObjectReference.Create(this);
        await _module.InvokeVoidAsync("initialize", _textareaElement, _dotNetReference);
    }

    [JSInvokable("NotifyValueChanged")]
    public async Task NotifyValueChanged(string tableHtml)
    {
        Value = tableHtml;

        if (ValueChanged.HasDelegate)
        {
            await ValueChanged.InvokeAsync(Value);
        }

        if (TableUpdated.HasDelegate)
        {
            await TableUpdated.InvokeAsync();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_isDisposed)
        {
            return;
        }

        _isDisposed = true;

        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("dispose", _textareaElement);
            }
            catch (JSDisconnectedException)
            {
                // Ignore teardown while disconnected.
            }

            try
            {
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Ignore teardown while disconnected.
            }
        }

        _dotNetReference?.Dispose();
        _module = null;
        _dotNetReference = null;
    }

}
