@inherits LayoutComponentBase
@inject Configuration.IConfigurationService ConfigurationService

<div class="site-shell">
    <a class="skip-link" href="#main-content">Перейти до вмісту</a>

    <div class="layout-container">
        <header class="site-header">
            <div class="header-inner">
                <a class="brand" href="/" aria-label="Kwytka — на головну">
                    <img class="brand-mark" src="images/log2.webp" alt="" />
                    <span class="brand-wordmark">KWYTKA</span>
                </a>

                <nav class="site-nav" aria-label="Головна навігація">
                    <NavLink href="price">Наявність асортименту</NavLink>
                    @if (ConfigurationService.Data.IsSaleEnabled)
                    {
                        <NavLink class="sale-nav-link" href="sale">Розпродаж</NavLink>
                    }
                    <NavLink href="contacts">Контакти</NavLink>
                </nav>
            </div>
        </header>

        <main id="main-content" class="page-surface">
            @Body
        </main>
    </div>

    <footer class="site-footer">
        &copy; Kwytka, @DateTime.Now.Year, v.@AppVersion
    </footer>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private static string AppVersion => typeof(MainLayout).Assembly.GetName().Version?.ToString() ?? "unknown";
}
